          "Anchored": true,
          "Color": [0.38823, 0.37254, 0.38823],
          "Locked": true,
          "Position": [0, -10, 0],
          "Size": [512, 20, 512]
        }
      },
      "Lanes": {
        "$className": "Folder",
        "Lane1": {
          "$className": "Folder",
          "Waypoints": {
            "$className": "Folder",
            "1": { "$className": "Part", "$properties": { "Anchored": true, "CanCollide": false, "CanQuery": false, "Transparency": 0.5, "Color": [0.2, 0.6, 1], "Position": [-200, 2, -60], "Size": [4, 1, 4] } },
            "2": { "$className": "Part", "$properties": { "Anchored": true, "CanCollide": false, "CanQuery": false, "Transparency": 0.5, "Color": [0.2, 0.6, 1], "Position": [-100, 2, -60], "Size": [4, 1, 4] } },
            "3": { "$className": "Part", "$properties": { "Anchored": true, "CanCollide": false, "CanQuery": false, "Transparency": 0.5, "Color": [0.2, 0.6, 1], "Position": [0, 2, -60], "Size": [4, 1, 4] } },
            "4": { "$className": "Part", "$properties": { "Anchored": true, "CanCollide": false, "CanQuery": false, "Transparency": 0.5, "Color": [0.2, 0.6, 1], "Position": [100, 2, -60], "Size": [4, 1, 4] } },
            "5": { "$className": "Part", "$properties": { "Anchored": true, "CanCollide": false, "CanQuery": false, "Transparency": 0.5, "Color": [0.2, 0.6, 1], "Position": [200, 2, -60], "Size": [4, 1, 4] } }
          }
        },
        "Lane2": {
          "$className": "Folder",
          "Waypoints": {
            "$className": "Folder",
            "1": { "$className": "Part", "$properties": { "Anchored": true, "CanCollide": false, "CanQuery": false, "Transparency": 0.5, "Color": [1, 0.6, 0.2], "Position": [-200, 2, 60], "Size": [4, 1, 4] } },
            "2": { "$className": "Part", "$properties": { "Anchored": true, "CanCollide": false, "CanQuery": false, "Transparency": 0.5, "Color": [1, 0.6, 0.2], "Position": [-100, 2, 60], "Size": [4, 1, 4] } },
            "3": { "$className": "Part", "$properties": { "Anchored": true, "CanCollide": false, "CanQuery": false, "Transparency": 0.5, "Color": [1, 0.6, 0.2], "Position": [0, 2, 60], "Size": [4, 1, 4] } },
            "4": { "$className": "Part", "$properties": { "Anchored": true, "CanCollide": false, "CanQuery": false, "Transparency": 0.5, "Color": [1, 0.6, 0.2], "Position": [100, 2, 60], "Size": [4, 1, 4] } },
            "5": { "$className": "Part", "$properties": { "Anchored": true, "CanCollide": false, "CanQuery": false, "Transparency": 0.5, "Color": [1, 0.6, 0.2], "Position": [200, 2, 60], "Size": [4, 1, 4] } }
          }
        }
      }
    },

    "Lighting": {
      "$properties": {
        "Ambient": [0, 0, 0],
        "Brightness": 2,
        "GlobalShadows": true,
        "Outlines": false,
        "Technology": "Voxel"
      }
    },

    "SoundService": {
      "$properties": {
        "RespectFilteringEnabled": true
      }
    }
